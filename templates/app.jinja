{#This is the main app in jinja templating, will probably have to separate the components later down the line, because its very long#}

{% extends "base" %}
{% from "components" import brand_logo %}

{% block title %}GREENSEER - Tactical Interface{% endblock %}

{# Inject flex-row specifically for the app layout #}
{% block body_classes %}flex-row{% endblock %}

{% block content %}
<div id="sidebar" class="relative inset-y-0 left-0 z-50 w-[300px] bg-surface-container p-6 flex flex-col border-r border-outline-ghost shrink-0">
  
  {{ brand_logo() }}

  <div class="mt-16 flex flex-col gap-6 flex-1">
    <button onclick="switchTab('welcome-tab', this)" class="nav-item border-l-2 border-primary bg-surface-container-highest text-primary p-4 text-left font-space uppercase tracking-[0.1em] transition-colors duration-200">
      System Status
    </button>
    <button onclick="switchTab('map-tab', this)" class="nav-item border-l-2 border-transparent text-outline-variant hover:bg-surface-container-highest hover:text-primary hover:border-primary p-4 text-left font-space uppercase tracking-[0.1em] transition-colors duration-200">
      Map
    </button>
    <button onclick="switchTab('data-tab', this)" class="nav-item border-l-2 border-transparent text-outline-variant hover:bg-surface-container-highest hover:text-primary hover:border-primary p-4 text-left font-space uppercase tracking-[0.1em] transition-colors duration-200">
      Asset Telemetry
    </button>

    <button onclick="window.location.href = '/logout'" class="mt-auto border-l-2 border-transparent text-error hover:bg-surface-container-highest p-4 text-left font-space uppercase tracking-[0.1em] transition-colors duration-200">
      Log out
    </button>
  </div>
</div>

<div class="flex-1 flex flex-col relative overflow-hidden h-full">

  <div id="welcome-tab" class="workspace block flex-1 px-16 pt-16 pb-16 overflow-y-auto">
    <h1 class="font-space text-[3.5rem] leading-none text-on-surface -ml-1 pb-6 shrink-0">System Overview</h1>
    <div class="grid grid-cols-2 gap-6 mt-4">
      <div class="col-span-2 bg-surface-container-low p-10 border border-outline-ghost relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-r from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <h2 class="font-space text-2xl text-primary mb-4 uppercase tracking-widest">Welcome, {{ user.name | default("Operator") }}!</h2>
        <p class="font-sans text-on-surface leading-relaxed max-w-3xl text-lg mb-6">
          Welcome to the greenseer system. The main goal of this system is to provide force multiplication through informational support.
        </p>
      </div>

      <div class="bg-surface-container p-8">
        <div class="text-outline-variant font-space uppercase tracking-widest text-sm mb-2">Active Assets</div>
        <div class="font-space text-5xl text-primary">{{ stats.active_assets | default("00") }}</div>
      </div>
      <div class="bg-surface-container p-8">
        <div class="text-outline-variant font-space uppercase tracking-widest text-sm mb-2">Signal Integrity</div>
        <div class="font-space text-5xl text-[#dee5ff]">{{ stats.signal_integrity | default("0.0") }}%</div>
      </div>
    </div>

    <div class="mt-12 border-t border-outline-ghost pt-10">
      <h3 class="font-space text-xl text-outline-variant mb-6 uppercase tracking-[0.15em] flex items-center gap-3">
        <div class="w-1.5 h-1.5 bg-outline-variant animate-pulse"></div>
        Tracking Configuration
      </h3>
      
      <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        {% for group_name, group_assets in asset_groups|items %}
        <div class="bg-surface-container border border-outline-ghost p-6 tracking-group">
          
          <label class="flex items-center gap-4 cursor-pointer mb-5 pb-5 border-b border-outline-ghost group">
            <input type="checkbox" checked class="parent-checkbox shrink-0 cursor-pointer appearance-none transition-all duration-200 w-6 h-6 bg-surface-container-high border-2 border-outline-variant hover:border-primary checked:bg-primary checked:border-primary checked:bg-contain checked:bg-center checked:bg-no-repeat checked:bg-[url('data:image/svg+xml,%3Csvg%20viewBox=%220%200%2016%2016%22%20fill=%22%23060e20%22%20xmlns=%22http://www.w3.org/2000/svg%22%3E%3Crect%20x=%224%22%20y=%224%22%20width=%228%22%20height=%228%22%20/%3E%3C/svg%3E')] indeterminate:bg-outline-variant indeterminate:border-outline-variant indeterminate:bg-contain indeterminate:bg-center indeterminate:bg-no-repeat indeterminate:bg-[url('data:image/svg+xml,%3Csvg%20viewBox=%220%200%2016%2016%22%20fill=%22%23060e20%22%20xmlns=%22http://www.w3.org/2000/svg%22%3E%3Crect%20x=%223%22%20y=%227%22%20width=%2210%22%20height=%222%22%20/%3E%3C/svg%3E')] shadow-[0_0_10px_rgba(107,255,143,0.1)]">
            <span class="font-space text-lg text-on-surface uppercase tracking-widest group-hover:text-primary transition-colors select-none">
              {{ group_name | replace('_', ' ') }}
            </span>
          </label>
          
          <div class="flex flex-col gap-4 pl-2">
            {% for asset in group_assets %}
            <label class="flex items-center gap-4 cursor-pointer group/child">
              <input type="checkbox" checked class="child-checkbox shrink-0 cursor-pointer appearance-none transition-all duration-200 w-5 h-5 bg-surface-container-high border-2 border-outline-variant hover:border-primary checked:bg-primary checked:border-primary checked:bg-contain checked:bg-center checked:bg-no-repeat checked:bg-[url('data:image/svg+xml,%3Csvg%20viewBox=%220%200%2016%2016%22%20fill=%22%23060e20%22%20xmlns=%22http://www.w3.org/2000/svg%22%3E%3Crect%20x=%224%22%20y=%224%22%20width=%228%22%20height=%228%22%20/%3E%3C/svg%3E')]">
              <div class="flex items-center gap-3 font-sans text-sm select-none">
                <span class="text-on-surface group-hover/child:text-primary transition-colors {% if asset.status == 'Offline' %}opacity-50{% endif %}">
                  {{ asset.name }}
                </span>
                {% if asset.status == 'Offline' %}
                  <span class="px-2 py-0.5 bg-outline-ghost text-outline-variant font-space text-[0.65rem] uppercase tracking-wider clip-status">Offline</span>
                {% endif %}
              </div>
            </label>
            {% endfor %}
          </div>
          
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div id="map-tab" class="workspace hidden flex-1 px-16 pt-16 pb-16 overflow-hidden flex flex-col">
    <h1 class="font-space text-[3.5rem] leading-none text-on-surface -ml-1 pb-6 shrink-0">Map</h1>
    <div class="w-full flex-1 bg-surface-container-low map-grid relative border border-outline-ghost overflow-hidden group">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,theme(colors.surface-container-low)_100%)] pointer-events-none"></div>

      {% for marker in map_markers %}
      <div class="absolute flex flex-col items-center gap-1 cursor-pointer hover:-translate-y-1 transition-transform duration-200 {% if marker.status == 'Offline' %}opacity-60{% endif %}" style="top: {{ marker.y }}%; left: {{ marker.x }}%">
        
        {% if marker.status == 'Active' %}
        <div class="bg-secondary-container text-on-secondary-container px-[14px] py-[6px] font-space text-[0.75rem] font-bold uppercase tracking-[0.1em] inline-flex items-center gap-2 clip-status">
          <div class="w-1.5 h-1.5 bg-primary rounded-full shadow-[0_0_8px_theme(colors.primary)] animate-pulse" style="animation-delay: {{ loop.index0 * 0.2 }}s"></div>
          {{ marker.id }}
        </div>
        <div class="w-3 h-3 bg-primary shadow-[0_0_15px_theme(colors.primary)]"></div>
        {% else %}
        <div class="bg-outline-ghost text-outline-variant px-[14px] py-[6px] font-space text-[0.75rem] font-bold uppercase tracking-[0.1em] inline-flex items-center gap-2 clip-status">
          Offline
        </div>
        <div class="w-3 h-3 bg-outline-variant"></div>
        {% endif %}

      </div>
      {% endfor %}
      
    </div>
  </div>

  <div id="data-tab" class="workspace hidden flex-1 px-16 pt-16 pb-16 overflow-hidden flex flex-col">
    <h1 class="font-space text-[3.5rem] leading-none text-on-surface -ml-1 pb-6 shrink-0">Telemetry Array</h1>
    <div class="flex-1 overflow-x-auto overflow-y-auto">
      <table class="w-full min-w-[800px] border-separate border-spacing-y-6">
        <thead>
          <tr>
            <th class="font-space uppercase tracking-[0.1rem] text-outline-variant text-left px-6 text-[0.85rem] pb-2">Asset name</th>
            <th class="font-space uppercase tracking-[0.1rem] text-outline-variant text-left px-6 text-[0.85rem] pb-2">Status</th>
            <th class="font-space uppercase tracking-[0.1rem] text-outline-variant text-left px-6 text-[0.85rem] pb-2">Coordinates</th>
            <th class="font-space uppercase tracking-[0.1rem] text-outline-variant text-left px-6 text-[0.85rem] pb-2">Fuel / Power</th>
            <th class="font-space uppercase tracking-[0.1rem] text-outline-variant text-left px-6 text-[0.85rem] pb-2">Last Ping</th>
          </tr>
        </thead>
        <tbody>
          {% for asset in assets %}
          <tr class="bg-surface-container hover:bg-surface-container-highest transition-colors duration-200 group {% if asset.status == 'Offline' %}opacity-75{% endif %}">
            <td class="p-6 {% if asset.status == 'Offline' %}text-outline-variant{% else %}text-primary{% endif %} font-space font-bold whitespace-nowrap">
              {{ asset.name }}
            </td>
            <td class="p-6">
              {% if asset.status == 'Active' %}
              <div class="bg-secondary-container text-on-secondary-container px-3 py-1 font-space text-[0.7rem] font-bold uppercase tracking-[0.1em] inline-flex items-center gap-2 clip-status">
                <div class="w-1.5 h-1.5 bg-primary rounded-full shadow-[0_0_8px_theme(colors.primary)]"></div>
                Active
              </div>
              {% else %}
              <div class="bg-outline-ghost text-outline-variant px-3 py-1 font-space text-[0.7rem] font-bold uppercase tracking-[0.1em] inline-flex items-center gap-2 clip-status">
                Offline
              </div>
              {% endif %}
            </td>
            <td class="p-6 text-on-surface whitespace-nowrap">{{ asset.coords }}</td>
            <td class="p-6 {% if asset.status == 'Offline' %}text-outline-variant{% else %}text-on-surface{% endif %}">{{ asset.fuel }}</td>
            <td class="p-6 {% if asset.status == 'Offline' %}text-outline-variant{% else %}text-on-surface{% endif %} whitespace-nowrap">{{ asset.last_ping }} ago</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
  function switchTab(tabId, element) {
    document.querySelectorAll(".workspace").forEach((el) => {
      el.classList.remove("block");
      el.classList.add("hidden");
    });
    document.getElementById(tabId).classList.remove("hidden");
    document.getElementById(tabId).classList.add("block");

    document.querySelectorAll(".nav-item").forEach((el) => {
      el.classList.remove("bg-surface-container-highest", "text-primary", "border-primary");
      el.classList.add("border-transparent", "text-outline-variant");
    });
    element.classList.remove("border-transparent", "text-outline-variant");
    element.classList.add("bg-surface-container-highest", "text-primary", "border-primary");
  }

  // Grouped Checkbox Logic
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll('.tracking-group').forEach(group => {
      const parentCb = group.querySelector('.parent-checkbox');
      const childCbs = Array.from(group.querySelectorAll('.child-checkbox'));

      // When the parent is clicked, set all children to match
      parentCb.addEventListener('change', (e) => {
        childCbs.forEach(child => child.checked = e.target.checked);
      });

      // When a child is clicked, update the parent's state
      childCbs.forEach(child => {
        child.addEventListener('change', () => {
          const allChecked = childCbs.every(c => c.checked);
          const noneChecked = childCbs.every(c => !c.checked);

          if (allChecked) {
            parentCb.checked = true;
            parentCb.indeterminate = false;
          } else if (noneChecked) {
            parentCb.checked = false;
            parentCb.indeterminate = false;
          } else {
            parentCb.checked = false; // Required for indeterminate to show visually
            parentCb.indeterminate = true;
          }
        });
      });
    });
  });
</script>
{% endblock %}
